# GBA Recommendation Service — environment template.
# Copy to .env and fill REAL values there. NEVER commit real secrets.
# .env is gitignored.

# --- Database (read-only login REQUIRED; never use sa) ---
DB_HOST=127.0.0.1
DB_PORT=1433
DB_NAME=ConcordDb_V5
DB_USER=gba_reco_ro
DB_PASSWORD=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
QUERY_TIMEOUT=25

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL=3600

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
# Shared secret the trusted gba-server proxy must present as X-Internal-Api-Key.
# UNSET = service runs OPEN (no auth) — dev only. Set a strong value in every
# non-local deployment; the middleware enforces it ONLY when this is non-empty.
# INTERNAL_API_KEY=
# Browser CORS origins (comma-free JSON list via pydantic). Defaults to the
# gba-server/console origins when unset; server-to-server callers send no Origin.
# CORS_ALLOW_ORIGINS=["http://localhost:8083","https://gba-console-dev.85.17.167.167.nip.io","http://127.0.0.1:8083"]

# --- Recommendation defaults ---
DEFAULT_TOP_N=25
REPURCHASE_COUNT=20
DISCOVERY_COUNT=5
MAX_PER_GROUP=3
