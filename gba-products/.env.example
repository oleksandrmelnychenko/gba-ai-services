# GBA Products Service — environment template. Copy to .env (gitignored). No real secrets here.

# --- Database (read-only login REQUIRED; never use sa) ---
DB_HOST=127.0.0.1
DB_PORT=1433
DB_NAME=ConcordDb_V5
DB_USER=gba_reco_ro
DB_PASSWORD=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=2
CACHE_TTL=3600

# --- API ---
API_HOST=0.0.0.0
API_PORT=8005
LOG_LEVEL=INFO
# Shared secret the gba-server proxy must send as X-Internal-Api-Key. Leave empty for local dev
# (service runs OPEN with a startup warning); set a strong value in every deployed environment.
INTERNAL_API_KEY=
# CORS_ALLOW_ORIGINS=["http://localhost:8083","https://gba-console-dev.85.17.167.167.nip.io","http://127.0.0.1:8083"]

# --- Inventory-health policy (calibrate on real data; do not guess) ---
VELOCITY_WINDOW_DAYS=180     # trailing window for the demand rate
DEAD_WINDOW_DAYS=365         # zero sales in this window + on-hand => dead
COVER_OVERSTOCK_DAYS=180     # days-of-cover above this => overstock
COVER_TARGET_MIN_DAYS=15     # healthy band lower bound
COVER_UNDERSTOCK_DAYS=7      # below this (with demand) => understock
SLOW_MAX_ANNUAL_UNITS=5      # <= units sold / yr => slow mover
RETURN_WINDOW_DAYS=365
