# GBA NBA (sales cockpit) — env template. Copy to .env (gitignored). No real secrets here.

# --- MongoDB (task state) ---
MONGO_URI=mongodb://gba_nba:CHANGE_ME@127.0.0.1:27017/?authSource=admin
MONGO_DB=gba_nba

# --- ConcordDb_V5 (read-only signals) ---
DB_HOST=127.0.0.1
DB_PORT=1433
DB_NAME=ConcordDb_V5
DB_USER=gba_reco_ro
DB_PASSWORD=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10

# --- downstream AI services ---
RECO_URL=http://127.0.0.1:8000
PROCURE_URL=http://127.0.0.1:8001
HTTP_TIMEOUT=30

# --- API ---
API_HOST=0.0.0.0
API_PORT=8002
LOG_LEVEL=INFO
# Shared secret the gba-server proxy must send as X-Internal-Api-Key. Leave empty for local dev
# (service runs OPEN with a startup warning); set a strong value in every deployed environment.
INTERNAL_API_KEY=

# --- NBA policy / throttling ---
MAX_ACTIVE_TASKS_PER_MANAGER=50
MAX_TASKS_PER_CLIENT_PER_DAY=2
TASK_TTL_DAYS=14
DISMISS_MUTE_DAYS=30
SERVICE_LEVEL_DUE_DAYS=3

# --- Scoring / model knobs (A/B-tunable without redeploy; bump MODEL_VERSION on change) ---
MODEL_VERSION=nba-v1
W_URGENCY=0.5
W_VALUE=0.3
W_CONFIDENCE=0.2
VALUE_SATURATION=6000
MAX_PACE_BOOST=1.25
TARGET_TRAILING_MONTHS=3
URGENCY_BAND_CRITICAL=0.85
URGENCY_BAND_HIGH=0.6
URGENCY_BAND_NORMAL=0.3
# Signal tuning
DEBT_MAX_AGE_DAYS=365
DEBT_MIN_AMOUNT=10
REORDER_MIN_CYCLE_DAYS=7
REORDER_MAX_OVERDUE_MULT=3.0
UBIQUITY_EXCLUDE_PCT=0.20
# cross_sell: only call reco for active clients (>= N orders in last D days), capped to top-N by turnover
CROSS_SELL_RECENT_DAYS=120
CROSS_SELL_MIN_ORDERS=3
CROSS_SELL_MAX_CLIENTS=40
RECO_CROSSSELL_TIMEOUT=8
# Feedback learning loop
FEEDBACK_WINDOW_DAYS=90
FEEDBACK_PENALTY_PER_REJECTION=0.15
FEEDBACK_PENALTY_FLOOR=0.5
