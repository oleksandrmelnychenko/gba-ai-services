# GBA Pricing Service — environment template.
# Copy to .env and fill REAL values there. NEVER commit real secrets.
# .env is gitignored.

# --- Database (read-only login REQUIRED; never use sa) ---
DB_HOST=127.0.0.1
DB_PORT=1433
DB_NAME=ConcordDb_V5
DB_USER=gba_reco_ro
DB_PASSWORD=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
QUERY_TIMEOUT=25

# --- Redis (db 3: 0=reco, 1=procure, 2=solvency, 3=pricing) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=3
CACHE_TTL=3600

# --- API ---
API_HOST=0.0.0.0
API_PORT=8004
LOG_LEVEL=INFO
# Shared secret the trusted gba-server proxy must present (X-Internal-Api-Key header).
# Leave EMPTY/unset to run OPEN (dev). Set a strong value in every non-local deployment;
# when set, all paths except /health require a matching X-Internal-Api-Key header (401 otherwise).
INTERNAL_API_KEY=
# Browser origins permitted by CORS (comma/JSON list). Defense-in-depth only — server-to-server
# calls carry no Origin and are unaffected. Defaults to the gba-server/console dev origins.
# CORS_ALLOW_ORIGINS=["http://localhost:8083","https://gba-console-dev.85.17.167.167.nip.io","http://127.0.0.1:8083"]

# --- Pricing model (A+B) ---
MODEL_VERSION=pricing-ab-v2
# Margin floor target: recommended price never below unit_cost_eur*(1+TARGET_MARGIN_PCT/100).
TARGET_MARGIN_PCT=12
# Peer band + cost lots are sampled over this trailing window (months, by Sale.Created).
TRAILING_WINDOW_MONTHS=12
# Pin the FX snapshot date for deterministic GetExchangedToEuroValue results.
# Leave empty to use each request's as_of_date.
FX_SNAPSHOT_DATE=
SYNTHETIC_LINE_PRODUCT_ID=25422404
