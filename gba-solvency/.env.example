# GBA Solvency Service — environment template.
# Copy to .env and fill REAL values there. NEVER commit real secrets.
# .env is gitignored.

# --- Database (read-only login REQUIRED; never use sa) ---
DB_HOST=127.0.0.1
DB_PORT=1433
DB_NAME=ConcordDb_V5
DB_USER=gba_reco_ro
DB_PASSWORD=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
QUERY_TIMEOUT=25

# --- Redis (db 2: 0=reco, 1=procure, 2=solvency) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=2
CACHE_TTL=3600

# --- API ---
API_HOST=0.0.0.0
API_PORT=8003
LOG_LEVEL=INFO
# Shared secret the gba-server proxy must send as X-Internal-Api-Key. Leave empty for local dev
# (service runs OPEN with a startup warning); set a strong value in every deployed environment.
INTERNAL_API_KEY=
# Browser CORS allow-list (comma-separated; defense-in-depth — server-to-server calls carry no
# Origin). Defaults to the gba-server / gba-console origins; uncomment to override.
# CORS_ALLOW_ORIGINS=["http://localhost:8083","https://gba-console-dev.85.17.167.167.nip.io","http://127.0.0.1:8083"]

# --- Solvency model ---
MODEL_VERSION=creditscore100-v2
WINDOW_MONTHS=12
# Pin the FX snapshot date for deterministic GetExchangedToEuroValue results.
# Leave empty to use each request's as_of_date.
FX_SNAPSHOT_DATE=
SYNTHETIC_LINE_PRODUCT_ID=25422404
TENURE_SENTINEL_DATE=1980-01-01
