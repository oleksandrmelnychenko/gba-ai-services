# GBA Forecast Service — environment template. Copy to .env (gitignored). No real secrets here.

# --- Database (read-only login REQUIRED; never use sa) ---
DB_HOST=127.0.0.1
DB_PORT=1433
DB_NAME=ConcordDb_V5
DB_USER=gba_reco_ro
DB_PASSWORD=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_LOGIN_TIMEOUT_SECONDS=5
DB_QUERY_TIMEOUT_SECONDS=30

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=3
CACHE_TTL=3600
REDIS_RETRY_INTERVAL_SECONDS=30

# --- API ---
API_HOST=0.0.0.0
API_PORT=8006
LOG_LEVEL=INFO
# Shared secret the gba-server proxy must send as X-Internal-Api-Key. Leave empty for local dev
# (service runs OPEN with a startup warning); set a strong value in every deployed environment.
INTERNAL_API_KEY=
# Local/dev-only escape hatch. Keep false in every shared/release environment.
ALLOW_OPEN_INTERNAL_API=false

# --- Forecast policy (calibrate on real data; do not guess) ---
FORECAST_HORIZON_MONTHS=6     # default # of months to project forward
MAX_FORECAST_HORIZON_MONTHS=24 # hard API cap to prevent accidental heavy calls
HISTORY_MONTHS=24             # trailing window of monthly history fed to the model
FORECAST_METHOD=auto          # auto (per-segment selection) | moving_avg | croston | sba
CROSTON_ALPHA=0.1             # smoothing constant for croston/sba
MIN_HISTORY_MONTHS=3          # < this many non-zero months => return [] (console «немає даних»)
