# GBA Procurement Service — environment template. Copy to .env (gitignored). No real secrets here.

# --- Database (read-only login REQUIRED; never use sa) ---
DB_HOST=127.0.0.1
DB_PORT=1433
DB_NAME=ConcordDb_V5
DB_USER=gba_reco_ro
DB_PASSWORD=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=1
CACHE_TTL=3600

# --- API ---
API_HOST=0.0.0.0
API_PORT=8001
LOG_LEVEL=INFO
# Shared secret the gba-server proxy must send as X-Internal-Api-Key. Leave empty for local dev
# (service runs OPEN with a startup warning); set a strong value in every deployed environment.
INTERNAL_API_KEY=
# Comma-separated browser origins allowed by CORS (defense-in-depth; server-to-server calls have no
# Origin so this only constrains browsers). Default = gba-server/console dev origins.
# CORS_ALLOW_ORIGINS=["http://localhost:8083","https://gba-console-dev.85.17.167.167.nip.io","http://127.0.0.1:8083"]

# --- Replenishment policy defaults ---
SERVICE_LEVEL=0.95          # target fill rate -> safety-stock z
FORECAST_HORIZON_DAYS=30    # demand horizon to cover
HISTORY_DAYS=120            # demand history window (tuned: moving_avg tracks recent rate; -12.4% economic_cost vs 365 on backtest panel)
DEFAULT_LEAD_TIME_DAYS=30   # fallback when a producer has no lead-time history

# --- Demand forecaster ---
FORECAST_METHOD=moving_avg  # moving_avg (default) | croston | sba (intermittent-demand methods)
CROSTON_ALPHA=0.1           # smoothing constant for croston/sba size & interval updates
